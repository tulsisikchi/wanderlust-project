<% layout("/layouts/boilerplate") %>

<div class="row mt-3">

    <div class="col-8 offset-3">
        <h3>Listing Details</h3>
    </div>

    <!-- LISTING CARD -->
    <div class="card col-lg-6 col-md-8 col-sm-10 offset-lg-3 offset-md-2 offset-sm-1 show-card"></div>
        <img
        src="<%= listing.image.url %>"
        class="card-img-top show-img"
        alt="listing_image">

        <div class="card-body">

            <p class="card-text">

                <b><%= listing.title %></b> <br>

                <%= listing.description %> <br>

                &#8377;
                <%= listing.price.toLocaleString("en-IN") %>
                <br>

                <%= listing.location %> <br>

                <%= listing.country %>

            </p>

        </div>

    </div>

    <!-- REVIEW FORM -->
    <hr>

    <div class="col-8 offset-3 mb-3">

        <h4>Leave a Review</h4>

        <form
        action="/listings/<%= listing._id %>/reviews"
        method="POST">

            <div class="mb-3">

                <label class="form-label">
                    Rating
                </label>

                <input
                type="range"
                min="1"
                max="5"
                name="review[rating]"
                class="form-range">

            </div>

            <div class="mb-3">

                <label class="form-label">
                    Comment
                </label>

                <textarea
                name="review[comment]"
                class="form-control"></textarea>

            </div>

            <button class="btn btn-dark">
                Submit Review
            </button>

        </form>

    </div>

    <!-- ALL REVIEWS -->
    <hr>

    <h4 class="col-8 offset-3 mb-3">
        All Reviews
    </h4>

    <div class="row">

        <% for(let review of listing.reviews) { %>

        <div class="card col-5 ms-3 mb-3 card-review">

            <div class="card-body">

                <h5 class="card-title">
                    Rating: <%= review.rating %>
                </h5>

                <p>
                    <b>
                        @<%= review.author ? review.author.username : "Anonymous" %>
                    </b>
                </p>

                <p class="card-text">
                    <%= review.comment %>
                </p>

                <form
                action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                method="POST">

                    <button class="btn btn-sm btn-dark">
                        Delete
                    </button>

                </form>

            </div>

        </div>

        <% } %>

    </div>

    <!-- EDIT & DELETE LISTING -->
    <div class="btns">

        <a
        href="/listings/<%= listing._id %>/edit"
        class="btn btn-dark col-2 offset-3 edit-btn">
            Edit
        </a>

        <form
        method="POST"
        action="/listings/<%= listing._id %>?_method=DELETE">

            <button class="btn btn-dark offset-5">
                Delete
            </button>

        </form>

    </div>

</div>